# Copy to .env (gitignored) and fill in what you have.
# ALL KEYS ARE OPTIONAL — the system degrades gracefully without them.
# See CLAUDE.md "Capability tiers" for exactly what each key unlocks.

# --- Twelve Labs (Tier 2: programmatic shot labeling) ---
# Without it, the vinyl-analyze skill has the agent label sampled
# frames itself (Tier 1) — slower but fully functional.
# Get a key at https://playground.twelvelabs.io (free tier available).
TWELVE_LABS_API_KEY=

# --- tribe-viral (Tier 3: OPTIONAL engagement tiebreaker) ---
# Only used to rank already-coherent edit variants. Never drives cuts.
# Sidney's Modal deployment; ~$0.10 per call.
SWIFT_LABS_TRIBE_API_KEY=
